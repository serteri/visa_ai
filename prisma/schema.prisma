generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model UserReport {
  id             String   @id @default(uuid())
  fullName       String?  @map("full_name")
  email          String
  phone          String?
  ipAddress      String?  @map("ip_address")
  preferredPath  String?  @map("preferred_path")
  source         String   @default("full_check")
  locale         String   @default("en")
  leadScore      Int?     @map("lead_score")
  leadTier       String?  @map("lead_tier")
  paymentStatus  String   @default("pending") @map("payment_status")
  unlockMethod   String?  @map("unlock_method")
  isUnlocked     Boolean  @default(false) @map("is_unlocked")
  pdfSent        Boolean  @default(false) @map("pdf_sent")
  reportJson     Json     @map("report_json")
  inputJson      Json     @map("input_json")
  createdAt      DateTime @default(now()) @map("created_at")
  unlockedAt     DateTime? @map("unlocked_at")

  @@map("user_reports")
}

model User {
  id            String    @id @default(uuid())
  name          String?
  email         String    @unique
  emailVerified DateTime? @map("email_verified")
  image         String?
  password      String?
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  accounts           Account[]
  sessions           Session[]
  savedCalculations  SavedCalculation[]
  savedQuizResults   SavedQuizResult[]
  savedReports       SavedReport[]
  visaTrackings      VisaTracking[]

  @@map("users")
}

model Account {
  id                String  @id @default(uuid())
  userId            String  @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(uuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model SavedCalculation {
  id           String   @id @default(uuid())
  userId       String   @map("user_id")
  visaSubclass String?  @map("visa_subclass")
  totalPoints  Int      @map("total_points")
  breakdown    Json?
  createdAt    DateTime @default(now()) @map("created_at")
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("saved_calculations")
}

model SavedQuizResult {
  id              String   @id @default(uuid())
  userId          String   @map("user_id")
  score           Int?
  readinessLevel  String?  @map("readiness_level")
  answers         Json?
  recommendations Json?
  createdAt       DateTime @default(now()) @map("created_at")
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("saved_quiz_results")
}

model SavedReport {
  id         String   @id @default(uuid())
  userId     String   @map("user_id")
  reportType String   @default("full_check") @map("report_type")
  reportUrl  String?  @map("report_url")
  reportData Json?    @map("report_data")
  language   String   @default("en")
  createdAt  DateTime @default(now()) @map("created_at")
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("saved_reports")
}

model VisaTracking {
  id           String    @id @default(uuid())
  userId       String    @map("user_id")
  visaSubclass String    @map("visa_subclass")
  status       String    @default("planning")
  notes        String?
  targetDate   DateTime? @map("target_date")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("visa_tracking")
}

model PointsAlert {
  id            String    @id @default(uuid())
  email         String
  targetPoints  Int       @map("target_points")
  visaSubclass  String    @map("visa_subclass")
  isActive      Boolean   @default(true) @map("is_active")
  createdAt     DateTime  @default(now()) @map("created_at")
  lastTriggered DateTime? @map("last_triggered")

  @@map("points_alerts")
}
